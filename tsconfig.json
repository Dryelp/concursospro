{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tailwind.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/main.tsx",
    "src/App.tsx",
    "src/features",
    "src/components/AppShell.tsx",
    "src/components/MetricCard.tsx",
    "src/components/SurfaceCard.tsx",
    "src/app/useEditalWorkspace.ts",
    "src/app/useSupabaseSession.ts",
    "src/lib/app-data.ts",
    "src/lib/concurseiro-data.ts",
    "src/lib/ai",
    "supabase"
  ]
}
